# PocketChange Protocol — Environment Variables
# Copy this file to .env and fill in your values (never commit .env)

# ── Solana RPC ────────────────────────────────────────────────────────────────
RPC_ENDPOINT=https://rpc.helius.xyz/?api-key=YOUR_HELIUS_API_KEY
RPC_WEBSOCKET=wss://rpc.helius.xyz/?api-key=YOUR_HELIUS_API_KEY

# Secondary RPC (Chainstack or QuickNode for redundancy)
CHAINSTACK_RPC=https://solana-mainnet.core.chainstack.com/YOUR_CHAINSTACK_KEY

# ── Jupiter Aggregator ────────────────────────────────────────────────────────
JUPITER_API_KEY=YOUR_JUPITER_API_KEY        # https://portal.jup.ag

# ── Wallet (Legacy & Multi-Wallet Swarm) ───────────────────────────────────────
WALLET_KEYPAIR_PATH=./real_wallet.json      # Legacy path (if not using swarm)

# SWARM WALLETS (Base58 private keys formatted)
PRIVATE_KEY_1=YOUR_BASE58_PRIVATE_KEY_1
PRIVATE_KEY_2=YOUR_BASE58_PRIVATE_KEY_2
PRIVATE_KEY_3=YOUR_BASE58_PRIVATE_KEY_3
PRIVATE_KEY_4=YOUR_BASE58_PRIVATE_KEY_4
PRIVATE_KEY_5=YOUR_BASE58_PRIVATE_KEY_5

# ── Ngrok (optional tunnel for dashboard) ────────────────────────────────────
NGROK_AUTHTOKEN=YOUR_NGROK_AUTH_TOKEN

# ── Trading Parameters (optional overrides) ───────────────────────────────────
# CEX/DEX arb
CEX_DEX_MIN_BASIS_BPS=10
CEX_DEX_TRADE_COMPOUND_PCT=0.20

# LST basis arb  
LST_MIN_BASIS_BPS=15
